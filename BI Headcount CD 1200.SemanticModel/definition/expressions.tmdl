expression 'Transformar Arquivo' =
		let
		    Fonte = (Parâmetro1 as binary) => let
		    Fonte = Excel.Workbook(Parâmetro1, null, true),
		    Tabela1_Table = Fonte{[Item="Tabela1",Kind="Table"]}[Data]
		in
		    Tabela1_Table
		in
		    Fonte
