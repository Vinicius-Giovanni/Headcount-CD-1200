expression Parâmetro1 = #"Arquivo de Amostra" meta [IsParameterQuery=true, BinaryIdentifier=#"Arquivo de Amostra", Type="Binary", IsParameterQueryRequired=true]
	lineageTag: aef5914d-6047-4e75-ae72-d2662a31b9e2
	queryGroup: 'Transformar Arquivo de Consulta1\Consultas Auxiliares'

	annotation PBI_ResultType = Binary

expression 'Transformar o Arquivo de Exemplo' =
		let
		    Fonte = Excel.Workbook(Parâmetro1, null, true),
		    Tabela1_Table = Fonte{[Item="Tabela1",Kind="Table"]}[Data]
		in
		    Tabela1_Table
	lineageTag: c84ce3e4-f7af-45dd-ae8b-601a7a4d3831
	queryGroup: 'Transformar Arquivo de Consulta1'

	annotation PBI_ResultType = Table

expression 'Arquivo de Amostra' =
		let
		    Fonte = SharePoint.Contents("https://viavarejo.sharepoint.com/sites/grupo_de_dados_wave", [ApiVersion = 15]),
		    #"Data Lakehouse" = Fonte{[Name="Data Lakehouse"]}[Content],
		    Compartilhados = #"Data Lakehouse"{[Name="Compartilhados"]}[Content],
		    #"Headcount CD 1200" = Compartilhados{[Name="Headcount CD 1200"]}[Content],
		    Navegação1 = #"Headcount CD 1200"{0}[Content]
		in
		    Navegação1
	lineageTag: c47af3e8-db86-43d6-ba5d-5927cf4eecb4
	queryGroup: 'Transformar Arquivo de Consulta1\Consultas Auxiliares'

	annotation PBI_ResultType = Binary

expression 'Transformar Arquivo' =
		let
		    Fonte = (Parâmetro1 as binary) => let
		    Fonte = Excel.Workbook(Parâmetro1, null, true),
		    Tabela1_Table = Fonte{[Item="Tabela1",Kind="Table"]}[Data]
		in
		    Tabela1_Table
		in
		    Fonte
	mAttributes: [ FunctionQueryBinding = "{""exemplarFormulaName"":""Transformar o Arquivo de Exemplo""}" ]
