expression 'Arquivo de Amostra' =
		let
		    Fonte = SharePoint.Contents("https://viavarejo.sharepoint.com/sites/grupo_de_dados_wave", [ApiVersion = 15]),
		    #"Data Lakehouse" = Fonte{[Name="Data Lakehouse"]}[Content],
		    Compartilhados = #"Data Lakehouse"{[Name="Compartilhados"]}[Content],
		    #"Headcount CD 1200" = Compartilhados{[Name="Headcount CD 1200"]}[Content],
		    Navegação1 = #"Headcount CD 1200"{0}[Content]
		in
		    Navegação1
